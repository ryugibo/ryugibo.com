---
import { profiles, users } from "../db/schema.ts";
import AppLayout from "../layouts/AppLayout.astro";
import { getDb } from "../lib/db.server.ts";

const title = "Create Snipt Profile";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const username = formData.get("username")?.toString();

  if (username && Astro.locals.user) {
    const env = import.meta.env;
    const db = getDb(env);

    try {
      // Create user entry
      await db
        .insert(users)
        .values({
          id: Astro.locals.user.id,
        })
        .onConflictDoNothing();

      // Create profile entry
      await db.insert(profiles).values({
        id: Astro.locals.user.id,
        username: username,
      });

      return Astro.redirect("/");
    } catch (e: unknown) {
      console.error(e);
      // Let it fall through to show the form again, ideally with error
    }
  }
}
---

<AppLayout title={title}>
  <div class="max-w-md mx-auto mt-20">
    <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl shadow-sm p-6 sm:p-8">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold tracking-tight mb-2">Welcome to Snipt</h1>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">Choose a username to start logging your snippets.</p>
      </div>

      <form method="POST" class="space-y-6">
        <div>
          <label for="username" class="block text-sm font-medium leading-6">Username</label>
          <div class="mt-2">
            <div class="flex rounded-md shadow-sm ring-1 ring-inset ring-zinc-300 dark:ring-zinc-700 focus-within:ring-2 focus-within:ring-inset focus-within:ring-primary-500 sm:max-w-md">
              <span class="flex select-none items-center pl-3 text-zinc-500 sm:text-sm">@</span>
              <input type="text" name="username" id="username" autocomplete="username" class="block flex-1 border-0 bg-transparent py-1.5 pl-1 text-zinc-900 dark:text-zinc-50 focus:ring-0 sm:text-sm sm:leading-6" placeholder="johndoe" required />
            </div>
          </div>
        </div>

        <button type="submit" class="w-full flex justify-center rounded-md bg-zinc-900 dark:bg-zinc-100 px-3 py-2 text-sm font-semibold text-white dark:text-zinc-900 shadow-sm hover:bg-zinc-700 dark:hover:bg-zinc-200 focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-zinc-600 transition-colors">
          Create Profile
        </button>
      </form>
    </div>
  </div>
</AppLayout>
