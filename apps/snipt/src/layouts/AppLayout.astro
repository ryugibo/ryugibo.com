---
import "../assets/app.css";

interface Props {
  title?: string;
}

const { title = "Snipt - Developer Microblog" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="antialiased selection:bg-primary-500 selection:text-white">
    <main class="max-w-2xl mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
      <slot />
    </main>
  </body>
</html>
